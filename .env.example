# ── Wallet ───────────────────────────────────────────────────────────────────
# BIP-39 mnemonic (12 or 24 words). Leave blank on first run to auto-generate.
MNEMONIC=

# ── Network ───────────────────────────────────────────────────────────────────
# Options: testnet | mainnet | dev
# testnet covers testnet2 (same networkId = 4)
NETWORK=testnet

# Local directory where the SDK stores wallet state
DATA_DIR=./wallet-data

# ── Token pair ────────────────────────────────────────────────────────────────
# BASE  = the token you buy/sell (the "quantity" currency)
# QUOTE = the token you pay with (the "price" currency)
# Currently active on testnet2: UCT / ETH
BASE_CURRENCY=UCT
QUOTE_CURRENCY=ETH

# ── Price filter (QUOTE per BASE unit) ────────────────────────────────────────
# We will FILL a sell listing  only if price <= MAX_BUY_PRICE
# We will FILL a buy  listing  only if price >= MIN_SELL_PRICE
# @chichi's current market: sell 0.1006, buy 0.0994
MAX_BUY_PRICE=0.1010
MIN_SELL_PRICE=0.0990

# ── Trade size ────────────────────────────────────────────────────────────────
# Integer strings in smallest denomination used by Sphere SDK.
# testnet example: "5" = 5 UCT; quote is computed from price.
TRADE_AMOUNT_BASE=5

# Swap timeout in seconds (min 60, max 86400)
SWAP_TIMEOUT_SECS=300

# ── Safety limits ─────────────────────────────────────────────────────────────
# Max swaps we allow to be in flight at the same time
MAX_CONCURRENT_SWAPS=3

# Milliseconds to wait between consecutive proposals (anti-spam)
PROPOSAL_COOLDOWN_MS=10000

# ── Testnet2 oracle API key ───────────────────────────────────────────────────
# Public testnet2 key — safe to commit, not a secret
ORACLE_API_KEY=sk_ddc3cfcc001e4a28ac3fad7407f99590
